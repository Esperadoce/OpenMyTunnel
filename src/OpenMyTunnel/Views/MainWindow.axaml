<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenMyTunnel.ViewModels"
        x:Class="OpenMyTunnel.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="OpenMyTunnel"
        Width="440"
        MinHeight="520"
        CanResize="False"
        Background="{StaticResource BgPrimaryBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Inter,Segoe UI,Helvetica Neue,Arial,sans-serif"
        FontSize="13"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>

        <!-- Section card -->
        <Style Selector="Border.card">
            <Setter Property="Background"    Value="{StaticResource BgSurfaceBrush}" />
            <Setter Property="CornerRadius"  Value="8" />
            <Setter Property="Padding"       Value="14" />
            <Setter Property="Margin"        Value="0,0,0,10" />
        </Style>

        <!-- Section header label -->
        <Style Selector="TextBlock.section-label">
            <Setter Property="Foreground"  Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontSize"    Value="10" />
            <Setter Property="FontWeight"  Value="SemiBold" />
            <Setter Property="Margin"      Value="0,0,0,8" />
        </Style>

        <!-- Field label -->
        <Style Selector="TextBlock.field-label">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontSize"   Value="11" />
            <Setter Property="Margin"     Value="0,0,0,3" />
        </Style>

        <!-- Input text boxes -->
        <Style Selector="TextBox">
            <Setter Property="Background"           Value="{StaticResource BgInputBrush}" />
            <Setter Property="Foreground"           Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush"          Value="#44446A" />
            <Setter Property="BorderThickness"      Value="1" />
            <Setter Property="CornerRadius"         Value="6" />
            <Setter Property="Padding"              Value="8,6" />
            <Setter Property="CaretBrush"           Value="{StaticResource AccentBrush}" />
            <Setter Property="SelectionBrush"       Value="#7C6AF740" />
        </Style>

        <!-- NumericUpDown -->
        <Style Selector="NumericUpDown">
            <Setter Property="Background"      Value="{StaticResource BgInputBrush}" />
            <Setter Property="Foreground"      Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush"     Value="#44446A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius"    Value="6" />
        </Style>

        <!-- Primary (connect/disconnect) button -->
        <Style Selector="Button.primary">
            <Setter Property="Background"  Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground"  Value="White" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding"     Value="0,9" />
            <Setter Property="FontWeight"  Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#6857E0" />
        </Style>
        <Style Selector="Button.primary:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="#55447A" />
            <Setter Property="Opacity"    Value="0.6" />
        </Style>

        <!-- Secondary (minimize) button -->
        <Style Selector="Button.secondary">
            <Setter Property="Background"   Value="#2A2A3E" />
            <Setter Property="Foreground"   Value="{StaticResource TextMutedBrush}" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding"      Value="12,9" />
            <Setter Property="BorderBrush"  Value="#44446A" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <!-- RadioButton -->
        <Style Selector="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Margin"     Value="0,0,16,0" />
        </Style>

        <!-- CheckBox -->
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontSize"   Value="11" />
        </Style>

        <!-- SSH key file picker zone -->
        <Style Selector="Button.key-picker">
            <Setter Property="Background"              Value="#18182A" />
            <Setter Property="BorderBrush"             Value="#44446A" />
            <Setter Property="BorderThickness"         Value="1" />
            <Setter Property="CornerRadius"            Value="8" />
            <Setter Property="Padding"                 Value="12,10" />
            <Setter Property="Cursor"                  Value="Hand" />
            <Setter Property="HorizontalAlignment"     Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
        <Style Selector="Button.key-picker:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1E1E38" />
        </Style>
        <Style Selector="Button.key-picker:pointerover">
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        </Style>
        <Style Selector="Button.key-picker:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#16163A" />
        </Style>

        <!-- Small clear (x) button inside the picker -->
        <Style Selector="Button.key-clear">
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="Foreground"      Value="#6B7280" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"         Value="6,4" />
            <Setter Property="CornerRadius"    Value="4" />
            <Setter Property="FontSize"        Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.key-clear:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#EF444425" />
            <Setter Property="Foreground" Value="#EF4444" />
        </Style>

    </Window.Styles>

    <Grid Margin="16" RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto">

        <!-- SERVER section -->
        <Border Grid.Row="0" Classes="card">
            <StackPanel>
                <TextBlock Classes="section-label" Text="SERVER" />

                <Grid ColumnDefinitions="*,10,90" RowDefinitions="Auto,6,Auto,10,Auto,6,Auto">

                    <TextBlock Grid.Row="0" Grid.Column="0" Classes="field-label" Text="Host" />
                    <TextBlock Grid.Row="0" Grid.Column="2" Classes="field-label" Text="SSH Port" />

                    <TextBox Grid.Row="2" Grid.Column="0"
                             Text="{Binding Host}"
                             Watermark="192.168.1.1" />

                    <NumericUpDown Grid.Row="2" Grid.Column="2"
                                   Minimum="1" Maximum="65535"
                                   Value="{Binding SshPort}"
                                   FormatString="0"
                                   ShowButtonSpinner="False" />

                    <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3"
                               Classes="field-label" Text="Username" />

                    <TextBox Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3"
                             Text="{Binding Username}"
                             Watermark="esperadoce" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- AUTHENTICATION section -->
        <Border Grid.Row="1" Classes="card">
            <StackPanel>
                <TextBlock Classes="section-label" Text="AUTHENTICATION" />

                <!-- Mode selector -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <RadioButton Content="Password"
                                 IsChecked="{Binding IsPasswordMode, Mode=TwoWay}" />
                    <RadioButton Content="SSH Key"
                                 IsChecked="{Binding IsKeyMode, Mode=TwoWay}" />
                </StackPanel>

                <!-- Password panel -->
                <StackPanel IsVisible="{Binding IsPasswordMode}">
                    <TextBlock Classes="field-label" Text="Password" />
                    <Grid ColumnDefinitions="*,8,Auto">
                        <TextBox Grid.Column="0"
                                 PasswordChar="*"
                                 Text="{Binding Password, Mode=TwoWay}"
                                 Watermark="SSH password" />
                        <ToggleButton Grid.Column="2"
                                      x:Name="RevealToggle"
                                      Padding="8,6"
                                      CornerRadius="6"
                                      Background="{StaticResource BgInputBrush}"
                                      Content="Show" />
                    </Grid>
                </StackPanel>

                <!-- SSH Key panel -->
                <StackPanel IsVisible="{Binding IsKeyMode}" Spacing="8">

                    <!-- File picker drop zone -->
                    <Button Classes="key-picker" Click="OnBrowseKeyFile">
                        <Grid ColumnDefinitions="44,*,Auto">

                            <!-- Icon: folder when empty, key when filled -->
                            <Border Grid.Column="0"
                                    Width="34" Height="34"
                                    Background="#7C6AF718"
                                    CornerRadius="8"
                                    VerticalAlignment="Center">
                                <Panel>
                                    <TextBlock Text="&#x1F4C2;"
                                               FontSize="17"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding !HasKeyFile}" />
                                    <TextBlock Text="&#x1F511;"
                                               FontSize="17"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding HasKeyFile}" />
                                </Panel>
                            </Border>

                            <!-- Text content -->
                            <StackPanel Grid.Column="1"
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center"
                                        Spacing="2">

                                <!-- Empty state -->
                                <TextBlock Text="No key file selected"
                                           FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           IsVisible="{Binding !HasKeyFile}" />
                                <TextBlock Text="Click to browse for your SSH private key"
                                           FontSize="11"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           IsVisible="{Binding !HasKeyFile}" />

                                <!-- Filled state -->
                                <TextBlock Text="{Binding KeyFileName}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           IsVisible="{Binding HasKeyFile}" />
                                <TextBlock Text="{Binding KeyFilePath}"
                                           FontSize="10"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           IsVisible="{Binding HasKeyFile}" />
                            </StackPanel>

                            <!-- Clear button (only visible when a file is chosen) -->
                            <Button Grid.Column="2"
                                    Classes="key-clear"
                                    Content="&#x2715;"
                                    IsVisible="{Binding HasKeyFile}"
                                    Command="{Binding ClearKeyFileCommand}"
                                    Margin="8,0,0,0"
                                    ToolTip.Tip="Remove key file" />
                        </Grid>
                    </Button>

                    <!-- Passphrase -->
                    <TextBlock Classes="field-label" Text="Passphrase (optional)" />
                    <TextBox PasswordChar="*"
                             Text="{Binding Passphrase, Mode=TwoWay}"
                             Watermark="Leave blank if none" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- TUNNEL section -->
        <Border Grid.Row="2" Classes="card">
            <StackPanel>
                <TextBlock Classes="section-label" Text="TUNNEL" />
                <Grid ColumnDefinitions="Auto,10,120" RowDefinitions="Auto,6,Auto">
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Classes="field-label"
                               Text="Local SOCKS Port"
                               VerticalAlignment="Center" />
                    <NumericUpDown Grid.Row="2" Grid.Column="0"
                                   Minimum="1024" Maximum="65535"
                                   Value="{Binding LocalSocksPort}"
                                   FormatString="0"
                                   ShowButtonSpinner="False" />
                </Grid>

                <Border Margin="0,10,0,0"
                        Background="#18182A"
                        CornerRadius="5"
                        Padding="8,6">
                    <TextBlock Text="{Binding CommandPreview}"
                               FontFamily="Cascadia Code,Consolas,monospace"
                               FontSize="11"
                               Foreground="#7C6AF7"
                               TextWrapping="Wrap" />
                </Border>
            </StackPanel>
        </Border>

        <!-- OPTIONS -->
        <CheckBox Grid.Row="3"
                  Margin="2,0,0,10"
                  Content="Start minimised to tray"
                  IsChecked="{Binding StartMinimised}" />

        <!-- STATUS -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    Spacing="8"
                    Margin="2,0,0,14">
            <Ellipse Width="10" Height="10"
                     Fill="{Binding StatusBrush}"
                     VerticalAlignment="Center" />
            <TextBlock Text="{Binding StatusText}"
                       VerticalAlignment="Center" />
        </StackPanel>

        <!-- Error message -->
        <TextBlock Grid.Row="5"
                   Margin="2,0,0,0"
                   Text="{Binding ErrorMessage}"
                   Foreground="#EF4444"
                   FontSize="11"
                   TextWrapping="Wrap"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

        <!-- ACTIONS -->
        <Grid Grid.Row="6" ColumnDefinitions="*,10,Auto">
            <Button Grid.Column="0"
                    Classes="primary"
                    Content="{Binding ConnectButtonText}"
                    Command="{Binding ConnectCommand}"
                    IsEnabled="{Binding !IsConnecting}"
                    HorizontalAlignment="Stretch" />

            <Button Grid.Column="2"
                    Classes="secondary"
                    Content="Minimize to Tray"
                    Click="OnMinimizeToTray" />
        </Grid>

    </Grid>
</Window>
