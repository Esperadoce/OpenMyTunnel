<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OpenMyTunnel.Views.TrayNotification"
        SystemDecorations="None"
        ShowInTaskbar="False"
        Topmost="True"
        Width="280"
        Height="68"
        WindowStartupLocation="Manual"
        CanResize="False"
        TransparencyLevelHint="Transparent"
        Background="Transparent">

    <Border Background="#2A2A3E"
            CornerRadius="10"
            BorderBrush="#44446A"
            BorderThickness="1"
            Padding="14,0">
        <StackPanel Orientation="Horizontal"
                    Spacing="12"
                    VerticalAlignment="Center">

            <Border Width="32" Height="32"
                    Background="#7C6AF7"
                    CornerRadius="8">
                <Viewbox Width="18" Height="18"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center">
                    <Path Fill="White"
                          Data="M12.65 10C11.83 7.67 9.61 6 7 6c-3.31 0-6 2.69-6 6s2.69 6 6 6c2.61 0 4.83-1.67 5.65-4H17v4h4v-4h2v-4H12.65zM7 14c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2z" />
                </Viewbox>
            </Border>

            <StackPanel VerticalAlignment="Center" Spacing="3">
                <TextBlock Text="OpenMyTunnel"
                           FontWeight="SemiBold"
                           Foreground="#E0E0F0"
                           FontFamily="Inter,Segoe UI,Helvetica Neue,Arial,sans-serif"
                           FontSize="13" />
                <TextBlock Text="Running in the system tray"
                           Foreground="#9090A0"
                           FontFamily="Inter,Segoe UI,Helvetica Neue,Arial,sans-serif"
                           FontSize="11" />
            </StackPanel>

        </StackPanel>
    </Border>

</Window>
